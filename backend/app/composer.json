{
  "name": "pos-system/backend",
  "type": "project",
  "config": {
    "audit": {
      "block-insecure": false
    }
  },
  "require": {
    "nikic/fast-route": "^1.3",
    "firebase/php-jwt": "^6.10",
    "stripe/stripe-php": "^13.0",
    "phpmailer/phpmailer": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}